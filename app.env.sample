# Taiga - Open-source project management
# Copy to app.env and customize

# Timezone
TZ=America/New_York

# Hostname / Domain
BASE_HOST_NAME=$HOSTNAME
BASE_DOMAIN_NAME=example.com

# App secret (min 32 chars)
APP_SECRET_KEY=changeme_secret_key_min_32_chars

# Database (PostgreSQL)
DB_CREATE_DATABASE_NAME=taiga
DB_USER_NAME=taiga
DB_USER_PASS=changeme_db_password

# RabbitMQ
RABBITMQ_USER=taiga
RABBITMQ_PASS=changeme_db_password
RABBITMQ_VHOST=taiga
